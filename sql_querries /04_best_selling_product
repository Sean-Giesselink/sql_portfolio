-- Question: What is the best selling product

SELECT
  oi.product_id,
  p.name,
  COUNT(oi.product_id) AS units_sold,
  ROUND(SUM(oi.sale_price), 2) AS product_price
FROM
  `bigquery-public-data.thelook_ecommerce.order_items` oi
LEFT JOIN
  `bigquery-public-data.thelook_ecommerce.products` p 
  ON oi.product_id = p.id
GROUP BY 
  product_id,
  p.name
ORDER BY
  units_sold DESC
LIMIT
  10
